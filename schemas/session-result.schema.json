{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maths-snapshots.local/schemas/session-result.schema.json",
  "title": "Phase 2 Maths Snapshot Session Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assessment_id",
    "session_id",
    "generated_at",
    "teacher",
    "student",
    "section_year_levels",
    "strand_summary",
    "overall_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "assessment_id": { "type": "string" },
    "session_id": { "type": "string" },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "teacher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" }
      }
    },
    "student": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" }
      }
    },
    "section_year_levels": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "section_id",
          "section_title",
          "strand",
          "attempts",
          "observed_year_level",
          "score_percent",
          "mastery_band",
          "confidence"
        ],
        "properties": {
          "section_id": { "type": "string" },
          "section_title": { "type": "string" },
          "strand": { "type": "string" },
          "target_year_variant": { "type": "integer", "minimum": 1, "maximum": 13 },
          "attempts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "variant_id",
                "year_level",
                "score_percent",
                "correct",
                "total",
                "skipped",
                "mastery_band",
                "item_results"
              ],
              "properties": {
                "variant_id": { "type": "string" },
                "year_level": { "type": "integer", "minimum": 1, "maximum": 13 },
                "score_percent": { "type": "number", "minimum": 0, "maximum": 100 },
                "correct": { "type": "integer", "minimum": 0 },
                "total": { "type": "integer", "minimum": 0 },
                "skipped": { "type": "integer", "minimum": 0 },
                "mastery_band": {
                  "type": "string",
                  "enum": ["Secure", "Developing", "Not Yet"]
                },
                "item_results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["item_id", "response", "is_correct", "is_skipped", "response_mode"],
                    "properties": {
                      "item_id": { "type": "string" },
                      "response": {
                        "oneOf": [
                          { "type": "string" },
                          { "type": "number" },
                          {
                            "type": "object",
                            "additionalProperties": {
                              "oneOf": [
                                { "type": "string" },
                                { "type": "number" }
                              ]
                            }
                          }
                        ]
                      },
                      "is_correct": { "type": "boolean" },
                      "is_skipped": { "type": "boolean" },
                      "response_mode": {
                        "type": "string",
                        "enum": ["answered", "skipped", "timed_out", "corrected", "guessed"]
                      }
                    }
                  }
                }
              }
            }
          },
          "observed_year_level": { "type": "string" },
          "score_percent": { "type": "number", "minimum": 0, "maximum": 100 },
          "mastery_band": {
            "type": "string",
            "enum": ["Secure", "Developing", "Not Yet"]
          },
          "confidence": {
            "type": "string",
            "enum": ["High", "Medium", "Low"]
          },
          "diagnostic_summary": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": [
              "last_secure_skill",
              "likely_misconception",
              "recommended_representation",
              "teacher_probe_needed",
              "teacher_probe_status",
              "confidence_risk_flags",
              "rationale"
            ],
            "properties": {
              "last_secure_skill": { "type": "string" },
              "likely_misconception": { "type": "string" },
              "recommended_representation": { "type": "string" },
              "teacher_probe_needed": { "type": "boolean" },
              "teacher_probe_status": {
                "type": "string",
                "enum": ["not_needed", "recommended", "completed"]
              },
              "confidence_risk_flags": {
                "type": "array",
                "items": { "type": "string" }
              },
              "rationale": { "type": "string" }
            }
          },
          "teacher_probe": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["status", "probe_items", "teacher_summary"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["not_run", "recommended", "completed"]
              },
              "probe_items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["probe_id", "prompt", "evidence_code", "response_options", "selected_option", "selected_label"],
                  "properties": {
                    "probe_id": { "type": "string" },
                    "prompt": { "type": "string" },
                    "evidence_code": { "type": "string" },
                    "response_options": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["id", "label"],
                        "properties": {
                          "id": { "type": "string" },
                          "label": { "type": "string" },
                          "misconception_hint": { "type": "string" }
                        }
                      }
                    }
                  ,
                    "selected_option": { "type": "string" },
                    "selected_label": { "type": "string" }
                  }
                }
              },
              "teacher_summary": { "type": "string" }
            }
          },
          "teacher_override": {
            "type": "object",
            "additionalProperties": false,
            "required": ["enabled", "reason"],
            "properties": {
              "enabled": { "type": "boolean" },
              "reason": { "type": "string" },
              "overridden_year": { "type": "string" }
            }
          }
        }
      }
    },
    "strand_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["strand_name", "observed_year_level", "confidence", "supporting_sections"],
        "properties": {
          "strand_name": { "type": "string" },
          "observed_year_level": { "type": "string" },
          "confidence": {
            "type": "string",
            "enum": ["High", "Medium", "Low"]
          },
          "supporting_sections": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "overall_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_operating_year", "confidence", "method"],
      "properties": {
        "observed_operating_year": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["High", "Medium", "Low"]
        },
        "method": { "type": "string" }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
